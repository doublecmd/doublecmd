{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.12.0/.schema/devbox.schema.json",
  "packages": {
    "fpc": "latest",
    "lazarus": {
      "version": "latest",
      "platforms": ["x86_64-linux", "aarch64-linux"]
    }
  },
  "shell": {
    "init_hook": [
      "echo 'Welcome to the Double Commander Devbox environment!'"
    ],
    "scripts": {
      "build": "./build.sh",
      "clean": "./clean.sh"
    }
  }
}
